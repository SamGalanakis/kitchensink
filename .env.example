APP_ENV=production
BIND_ADDR=0.0.0.0:8080
PUBLIC_BASE_URL=https://your-app.fly.dev
FRONTEND_DIR=/app/web/dist
APP_NAME=Kitchensink
SESSION_COOKIE_NAME=kitchensink_session

# Single private password login
ADMIN_USERNAME=operator
APP_PASSWORD=replace-me

# SurrealDB Cloud
SURREALDB_URL=wss://example.surreal.cloud
SURREALDB_NAMESPACE=main
SURREALDB_DATABASE=main
SURREALDB_TOKEN=
# Or set both:
# SURREALDB_USERNAME=
# SURREALDB_PASSWORD=

# Default OpenAI-compatible model settings used on first boot.
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-5.4
OPENAI_API_KEY=
MODEL_MAX_CONTEXT_TOKENS=120000

# Optional web search for the assistant.
TAVILY_API_KEY=

# Tigris / S3 object storage
BUCKET_NAME=
AWS_ENDPOINT_URL_S3=
AWS_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional local fallback when BUCKET_NAME is unset
LOCAL_ASSET_DIR=.data/assets
